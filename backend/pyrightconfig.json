{
    "pythonVersion": "3.12",
    "pythonPlatform": "Linux",
    "typeCheckingMode": "standard",
    "include": [
        "."
    ],
    "exclude": [
        "tests",
        "tools",
        "**/__pycache__"
    ],
    "reportMissingImports": true,
    "reportMissingTypeStubs": false,
    "reportUnnecessaryTypeIgnoreComment": "warning",
    "reportDeprecated": "warning",
    "reportDuplicateImport": "warning"
}
