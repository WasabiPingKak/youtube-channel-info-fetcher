# === Firestore ===
export FIRESTORE_DATABASE=(default)  # 或 "staging"
export GOOGLE_CLOUD_PROJECT=your-gcp-project-id
export GOOGLE_APPLICATION_CREDENTIALS=firebase-key.json
export FIREBASE_KEY_PATH=firebase-key.json  # tools/ 腳本使用

# === Google OAuth ===
export GOOGLE_CLIENT_ID=xxx
export GOOGLE_CLIENT_SECRET=xxx
export GOOGLE_REDIRECT_URI=https://xxx/oauth/callback
export FRONTEND_BASE_URL=https://xxx
export OAUTH_DEBUG_MODE=false

# === YouTube Data API ===
export API_KEY=xxx

# === 認證與權限 ===
export JWT_SECRET=xxx
export ADMIN_CHANNEL_IDS=UCxxxxx,UCxxxxx  # 逗號分隔的管理員頻道 ID
export ADMIN_API_KEY=xxx  # 內部 API 認證用

# === CORS ===
export ALLOWED_ORIGINS=https://xxxxx

# === WebSub ===
export WEBSUB_CALLBACK_URL=https://xxxxx/websub-callback
export WEBSUB_SECRET=xxx

# === Cloud Tasks（WebSub 非同步訂閱用）===
export CLOUD_TASKS_LOCATION=asia-east1
export CLOUD_TASKS_QUEUE=websub-subscribe
export CLOUD_RUN_SERVICE_URL=https://your-service-xxxxx.a.run.app

# === 遊戲別名 API ===
export GAME_ALIAS_ENDPOINT=https://xxxxx

# === 綠界金流（選填，僅贊助功能需要）===
export ECPAY_MERCHANT_ID=xxx
export ECPAY_HASH_KEY=xxx
export ECPAY_HASH_IV=xxx

# === 選填 ===
export ENV=local  # local / production
export RATE_LIMIT_STORAGE_URL=memory://  # 預設 in-memory，正式環境可用 redis://
